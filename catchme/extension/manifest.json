{
  "manifest_version": 3,
  "name": "CatchMe Page Capture",
  "version": "0.1.0",
  "description": "Extracts page content for CatchMe memory system",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
