{
    "web": {
        "host": "127.0.0.1",
        "port": 8765
    },

    "llm": {
        "provider": "openrouter",
        "api_key": "your-api-key-here",
        "api_url": "https://openrouter.ai/api/v1",
        "model": "google/gemini-3-flash-preview",
        "max_calls": 0,
        "max_images_per_cluster": 4
    },

    "filter": {
        "window_min_dwell": 3.0,
        "keyboard_cluster_gap": 3.0,
        "mouse_cluster_gap": 3.0
    },

    "summarize": {
        "language": "en",
        "max_tokens_l0": 1200,
        "max_tokens_l1": 1200,
        "max_tokens_l2": 1200,
        "max_tokens_l3": 1200,
        "temperature": 0.4,
        "max_workers": 3,
        "debounce_sec": 3.0,
        "save_interval_sec": 5.0
    },

    "retrieve": {
        "max_prompt_chars": 42000,
        "max_iterations": 15,
        "max_file_chars": 8000,
        "max_select_nodes": 10,
        "max_tokens_step": 8192,
        "max_tokens_answer": 8192,
        "temperature_select": 0.3,
        "temperature_answer": 0.5,
        "temperature_time_resolve": 0.1,
        "max_tokens_time_resolve": 1000
    }
}
